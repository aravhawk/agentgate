OPENAI_API_KEY="YOUR_API_KEY"

# Auth0 configuration
APP_BASE_URL="http://localhost:3000"
AUTH0_SECRET="use [openssl rand -hex 32] to generate a 32 bytes value"
AUTH0_DOMAIN="{yourDomain}"
AUTH0_CLIENT_ID="{yourClientId}"
AUTH0_CLIENT_SECRET="{yourClientSecret}"

# Demo mode: set to "false" to use real Google Calendar & GitHub APIs via Token Vault.
# Requires configuring Google OAuth2 and GitHub social connections in Auth0.
# Default (true) uses realistic mock data so you can demo the full Permission Contracts
# flow without any third-party OAuth setup.
DEMO_MODE="false"
